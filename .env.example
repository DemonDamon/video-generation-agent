# 本地运行环境变量模板
# 复制为 .env.local 并填入实际值，然后: export $(grep -v '^#' .env.local | xargs)

# ========== 必需 ==========
# 豆包 API Key（火山引擎控制台获取）
COZE_WORKLOAD_IDENTITY_API_KEY=your_api_key_here

# 豆包 API 基础 URL（示例为火山引擎 Ark）
COZE_INTEGRATION_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 对象存储（S3 兼容，用于视频输出；不配置则自动保存到本地 output/videos）
# COZE_BUCKET_ENDPOINT_URL=https://your-s3-endpoint.com
# COZE_BUCKET_NAME=your-bucket-name

# ========== 可选 ==========
# 本地视频输出目录（未配置对象存储时生效，默认 output/videos）
# LOCAL_VIDEO_OUTPUT_DIR=output/videos
# 本地视频 HTTP 访问地址（用于生成可点击链接，如 http://localhost:5000）
# LOCAL_VIDEO_BASE_URL=http://localhost:5000
# 项目根目录（默认当前目录）
# COZE_WORKSPACE_PATH=.

# 数据库（若使用记忆功能）
# PGDATABASE_URL=postgresql://user:pass@host:5432/dbname
